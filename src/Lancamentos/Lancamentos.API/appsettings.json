{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "LancamentosDb": "Host=localhost;Port=5432;Database=lancamentos;Username=postgres;Password=postgres"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "Outbox": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 50,
    "MaxTentativas": 10
  },
  "Jwt": {
    "Issuer": "fluxo-caixa",
    "Audience": "fluxo-caixa-clients",
    "SigningKey": "troque-esta-chave-em-producao-use-no-minimo-32-bytes!!",
    "ExpiryMinutes": 60
  },
  "Swagger": {
    "Enabled": true
  }
}
