{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ConsolidadoDb": "Host=localhost;Port=5432;Database=consolidado;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "RateLimiting": {
    "PermitPerSecond": 100,
    "QueueLimit": 50
  },
  "Jwt": {
    "Issuer": "fluxo-caixa",
    "Audience": "fluxo-caixa-clients",
    "SigningKey": "troque-esta-chave-em-producao-use-no-minimo-32-bytes!!",
    "ExpiryMinutes": 60
  },
  "Swagger": {
    "Enabled": true
  }
}
