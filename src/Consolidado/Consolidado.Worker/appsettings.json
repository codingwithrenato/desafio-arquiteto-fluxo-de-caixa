{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Information"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "ConsolidadoDb": "Host=localhost;Port=5433;Database=consolidado;Username=postgres;Password=postgres",
    "HangfireDb": "Host=localhost;Port=5433;Database=consolidado;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "PrefetchCount": 20
  },
  "Hangfire": {
    "CronFechamentoDiario": "5 0 * * *",
    "CronReconciliacao": "*/15 * * * *"
  }
}
